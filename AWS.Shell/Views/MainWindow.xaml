<pf:Window
    x:Class="AWS.Shell.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:shell="clr-namespace:AWS.Shell"
    Title="绿鑫资源 — 智能过磅系统"
    Width="1400" Height="900"
    MinWidth="1200" MinHeight="700"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    NonClientAreaHeight="48"
    ShowNonClientArea="True"
    Style="{StaticResource WindowWin10}"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <!-- 标题栏 -->
    <pf:Window.NonClientAreaContent>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Margin="12,0"
                       VerticalAlignment="Center"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="绿鑫资源 智能过磅系统" />

            <pf:Shield Grid.Column="1" Margin="4,0" Subject="V" Status="1.0.0"
                       Color="{DynamicResource PrimaryBrush}" />

            <!-- 主题切换 -->
            <Button Grid.Column="3" Width="36" Height="36"
                    Background="Transparent" BorderThickness="0"
                    ToolTip="切换深色/浅色主题"
                    Command="{Binding ToggleThemeCommand}">
                <pf:PackIcon Kind="WeatherNight" Width="18" Height="18"
                             Foreground="{DynamicResource PrimaryTextBrush}" />
            </Button>

            <!-- 当前用户 -->
            <StackPanel Grid.Column="4" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="8,0,16,0">
                <pf:PackIcon Kind="Account" Width="16" Height="16"
                             Foreground="{DynamicResource SecondaryTextBrush}" />
                <TextBlock Margin="4,0,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Text="{Binding CurrentUserDisplay, Mode=OneWay}" />
            </StackPanel>
        </Grid>
    </pf:Window.NonClientAreaContent>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />   <!-- 日志面板（折叠时占 0 高） -->
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!-- 左侧导航 -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    BorderThickness="0,0,1,0">
                <pf:SideMenu x:Name="SideNav"
                             Width="180" Margin="4"
                             ExpandMode="ShowAll"
                             SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}">
                    <pf:Interaction.Triggers>
                        <pf:EventTrigger EventName="SelectionChanged">
                            <pf:EventToCommand Command="{Binding NavigateCommand}"
                                               PassEventArgsToCommand="True" />
                        </pf:EventTrigger>
                    </pf:Interaction.Triggers>

                    <!-- 过磅操作 -->
                    <pf:SideMenuItem Header="过磅操作" Tag="WeighingView"
                                     FontSize="{DynamicResource FontSize.Body.Standard}">
                        <pf:SideMenuItem.Icon>
                            <pf:PackIcon Kind="ScaleBalance" Width="18" Height="18" />
                        </pf:SideMenuItem.Icon>
                        <pf:SideMenuItem Header="主操作台" Tag="WeighingView"
                                         Padding="20,0,0,0"
                                         FontSize="{DynamicResource FontSize.Body.Small}">
                            <pf:SideMenuItem.Icon>
                                <pf:PackIcon Kind="MonitorDashboard" Width="14" Height="14" />
                            </pf:SideMenuItem.Icon>
                        </pf:SideMenuItem>
                        <pf:SideMenuItem Header="待处理队列" Tag="QueueView"
                                         Padding="20,0,0,0"
                                         FontSize="{DynamicResource FontSize.Body.Small}">
                            <pf:SideMenuItem.Icon>
                                <pf:PackIcon Kind="FormatListBulleted" Width="14" Height="14" />
                            </pf:SideMenuItem.Icon>
                        </pf:SideMenuItem>
                    </pf:SideMenuItem>

                    <!-- 数据查询 -->
                    <pf:SideMenuItem Header="数据查询" Tag="ArchiveQueryView"
                                     FontSize="{DynamicResource FontSize.Body.Standard}">
                        <pf:SideMenuItem.Icon>
                            <pf:PackIcon Kind="DatabaseSearch" Width="18" Height="18" />
                        </pf:SideMenuItem.Icon>
                        <pf:SideMenuItem Header="存档查询" Tag="ArchiveQueryView"
                                         Padding="20,0,0,0"
                                         FontSize="{DynamicResource FontSize.Body.Small}">
                            <pf:SideMenuItem.Icon>
                                <pf:PackIcon Kind="FileSearch" Width="14" Height="14" />
                            </pf:SideMenuItem.Icon>
                        </pf:SideMenuItem>
                        <pf:SideMenuItem Header="数据导出" Tag="ExportView"
                                         Padding="20,0,0,0"
                                         FontSize="{DynamicResource FontSize.Body.Small}">
                            <pf:SideMenuItem.Icon>
                                <pf:PackIcon Kind="FileExport" Width="14" Height="14" />
                            </pf:SideMenuItem.Icon>
                        </pf:SideMenuItem>
                    </pf:SideMenuItem>

                    <!-- 统计分析 -->
                    <pf:SideMenuItem Header="统计分析" Tag="StatisticsView"
                                     FontSize="{DynamicResource FontSize.Body.Standard}">
                        <pf:SideMenuItem.Icon>
                            <pf:PackIcon Kind="ChartBar" Width="18" Height="18" />
                        </pf:SideMenuItem.Icon>
                        <pf:SideMenuItem Header="数据统计" Tag="StatisticsView"
                                         Padding="20,0,0,0"
                                         FontSize="{DynamicResource FontSize.Body.Small}">
                            <pf:SideMenuItem.Icon>
                                <pf:PackIcon Kind="ChartLine" Width="14" Height="14" />
                            </pf:SideMenuItem.Icon>
                        </pf:SideMenuItem>
                    </pf:SideMenuItem>

                    <!-- 基础数据（Admin） -->
                    <pf:SideMenuItem Header="基础数据"
                                     FontSize="{DynamicResource FontSize.Body.Standard}"
                                     Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <pf:SideMenuItem.Icon>
                            <pf:PackIcon Kind="DatabaseEdit" Width="18" Height="18" />
                        </pf:SideMenuItem.Icon>
                        <pf:SideMenuItem Header="客户管理" Tag="CustomerView"
                                         Padding="20,0,0,0"
                                         FontSize="{DynamicResource FontSize.Body.Small}">
                            <pf:SideMenuItem.Icon>
                                <pf:PackIcon Kind="AccountGroup" Width="14" Height="14" />
                            </pf:SideMenuItem.Icon>
                        </pf:SideMenuItem>
                        <pf:SideMenuItem Header="货物种类" Tag="GoodsCategoryView"
                                         Padding="20,0,0,0"
                                         FontSize="{DynamicResource FontSize.Body.Small}">
                            <pf:SideMenuItem.Icon>
                                <pf:PackIcon Kind="PackageVariant" Width="14" Height="14" />
                            </pf:SideMenuItem.Icon>
                        </pf:SideMenuItem>
                        <pf:SideMenuItem Header="车辆管理" Tag="VehicleView"
                                         Padding="20,0,0,0"
                                         FontSize="{DynamicResource FontSize.Body.Small}">
                            <pf:SideMenuItem.Icon>
                                <pf:PackIcon Kind="Truck" Width="14" Height="14" />
                            </pf:SideMenuItem.Icon>
                        </pf:SideMenuItem>
                    </pf:SideMenuItem>

                    <!-- 系统设置（Admin） -->
                    <pf:SideMenuItem Header="系统设置"
                                     FontSize="{DynamicResource FontSize.Body.Standard}"
                                     Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <pf:SideMenuItem.Icon>
                            <pf:PackIcon Kind="Cog" Width="18" Height="18" />
                        </pf:SideMenuItem.Icon>
                        <pf:SideMenuItem Header="串口配置" Tag="SerialPortSettingView"
                                         Padding="20,0,0,0"
                                         FontSize="{DynamicResource FontSize.Body.Small}">
                            <pf:SideMenuItem.Icon>
                                <pf:PackIcon Kind="SerialPort" Width="14" Height="14" />
                            </pf:SideMenuItem.Icon>
                        </pf:SideMenuItem>
                        <pf:SideMenuItem Header="用户管理" Tag="UserManageView"
                                         Padding="20,0,0,0"
                                         FontSize="{DynamicResource FontSize.Body.Small}">
                            <pf:SideMenuItem.Icon>
                                <pf:PackIcon Kind="AccountCog" Width="14" Height="14" />
                            </pf:SideMenuItem.Icon>
                        </pf:SideMenuItem>
                        <pf:SideMenuItem Header="云同步" Tag="CloudSyncView" IsEnabled="False"
                                         Padding="20,0,0,0"
                                         FontSize="{DynamicResource FontSize.Body.Small}">
                            <pf:SideMenuItem.Icon>
                                <pf:PackIcon Kind="CloudSync" Width="14" Height="14" />
                            </pf:SideMenuItem.Icon>
                        </pf:SideMenuItem>
                    </pf:SideMenuItem>
                </pf:SideMenu>
            </Border>

            <!-- 右侧内容区 -->
            <ContentControl Grid.Column="1"
                            prism:RegionManager.RegionName="{x:Static shell:RegionNames.Main}" />
        </Grid>

        <!-- ══ 日志面板 ══ -->
        <Border Grid.Row="1"
                Visibility="{Binding IsLogPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                BorderBrush="{DynamicResource PrimaryBrush}"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource WindowBrush}">
            <Grid Height="180">
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 日志头部 -->
                <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" Padding="8,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <pf:PackIcon Kind="TextBoxOutline" Width="14" Height="14"
                                         Foreground="{DynamicResource SecondaryTextBrush}"
                                         VerticalAlignment="Center" />
                            <TextBlock Text="系统日志" Margin="5,0,0,0" FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Margin="10,0,0,0" FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding LogEntries.Count, Mode=OneWay}" />
                                <Run Text=" 条" />
                            </TextBlock>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Height="20" Padding="8,0"
                                Content="清空" FontSize="10"
                                Command="{Binding ClearLogCommand}"
                                Background="Transparent"
                                Foreground="{DynamicResource SecondaryTextBrush}"
                                BorderThickness="1" />
                    </Grid>
                </Border>

                <!-- 日志条目列表 -->
                <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding LogEntries}"
                                  x:Name="LogItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />   <!-- 时间 -->
                                        <ColumnDefinition Width="36" />   <!-- 级别 -->
                                        <ColumnDefinition Width="*" />    <!-- 消息 -->
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}"
                                               FontSize="10" FontFamily="Consolas"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding LevelTag}"
                                               FontSize="10" FontFamily="Consolas"
                                               FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4CAF50" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warn">
                                                        <Setter Property="Foreground" Value="#FF9800" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                        <Setter Property="Foreground" Value="#F44336" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Grid.Column="2" FontSize="10"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource PrimaryTextBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                        <Setter Property="Foreground" Value="#F44336" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warn">
                                                        <Setter Property="Foreground" Value="#FF9800" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="{Binding Source, StringFormat='[{0}] ', Mode=OneWay}" />
                                        <Run Text="{Binding Message, Mode=OneWay}" />
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Background="{DynamicResource RegionBrush}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,4,0"
                             Fill="{Binding SerialPortStatusBrush}" />
                    <TextBlock Text="{Binding SerialPortStatusText}"
                               Foreground="{Binding SerialPortStatusBrush}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="当前用户：" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <Run Text="{Binding CurrentUserDisplay, Mode=OneWay}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Button Height="22" Padding="8,0" Margin="0,0,8,0"
                            FontSize="10" BorderThickness="1"
                            Background="Transparent"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Command="{Binding ToggleLogPanelCommand}"
                            ToolTip="展开/收起日志面板">
                        <StackPanel Orientation="Horizontal">
                            <pf:PackIcon Kind="TextBoxOutline" Width="12" Height="12"
                                         VerticalAlignment="Center" />
                            <TextBlock Text=" 日志" FontSize="10" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding SystemTime}" VerticalAlignment="Center" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{Binding ClosingCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
</pf:Window>
