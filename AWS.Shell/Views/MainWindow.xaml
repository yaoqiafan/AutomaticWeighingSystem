<pf:Window
    x:Class="AWS.Shell.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:AWS.Shell.Controls"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:shell="clr-namespace:AWS.Shell"
    Width="1400"
    Height="900"
    MinWidth="1200"
    MinHeight="700"
    prism:ViewModelLocator.AutoWireViewModel="True"
    NonClientAreaHeight="60"
    ShowNonClientArea="True"
    Style="{StaticResource WindowWin10}"
    UIIcon="/AWS.UI;component/Images/recycle.png"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized">

    <pf:Window.Resources>
        <!--  侧边栏导航项样式：平铺、点击选中高亮、左侧主色竖条标记当前项  -->
        <Style TargetType="ctrl:SidebarItem">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Standard}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <!--  Ripple.OnApplyTemplate 从 TemplatedParent 读取 Feedback，需在此处设置  -->
            <Setter Property="pf:RippleAssist.Feedback" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ctrl:SidebarItem">
                        <Border
                            x:Name="Bd"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="5,0,0,0"
                            ClipToBounds="True">
                            <pf:Ripple
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Center">
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <ContentPresenter VerticalAlignment="Center" Content="{TemplateBinding Icon}" />
                                    <TextBlock
                                        x:Name="HeaderText"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="{TemplateBinding FontSize}"
                                        FontWeight="{TemplateBinding FontWeight}"
                                        Foreground="{TemplateBinding Foreground}"
                                        Text="{TemplateBinding Header}">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform x:Name="TextTranslate" X="0" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </pf:Ripple>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="HeaderText"
                                                Storyboard.TargetProperty="FontSize"
                                                To="15"
                                                Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetName="TextTranslate"
                                                Storyboard.TargetProperty="X"
                                                To="6"
                                                Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                FillBehavior="Stop"
                                                Storyboard.TargetName="HeaderText"
                                                Storyboard.TargetProperty="FontSize"
                                                To="13"
                                                Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                FillBehavior="Stop"
                                                Storyboard.TargetName="TextTranslate"
                                                Storyboard.TargetProperty="X"
                                                To="0"
                                                Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource RegionBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </pf:Window.Resources>

    <!--  标题栏  -->
    <pf:Window.NonClientAreaContent>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Margin="12,0"
                VerticalAlignment="Center"
                FontSize="{DynamicResource FontSize.H1.Large}"
                FontWeight="Bold"
                Foreground="{DynamicResource PrimaryTextBrush}"
                Text="绿鑫资源 智能过磅系统" />

            <pf:Shield
                Grid.Column="1"
                Margin="4,0"
                Status="1.0.0"
                Subject="V"
                Color="{DynamicResource PrimaryBrush}" />

            <!--  主题切换  -->
            <Button VerticalAlignment="Top"
                x:Name="ThemeBtn"
                Grid.Column="3"
                Width="36"

                Background="Transparent"
                BorderThickness="0"
                Click="ToggleThemeBtn_Click"
                ToolTip="切换深色/浅色主题">
                <pf:PackIcon
                    x:Name="ThemeIcon"
                    Width="18"
                    Height="18"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                    Kind="WeatherSunny" />
            </Button>

           
        </Grid>
    </pf:Window.NonClientAreaContent>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />   
            <!--  日志面板（折叠时占 0 高）  -->
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!--  左侧导航  -->
            <Border
                Grid.Column="0"
                BorderBrush="{DynamicResource PrimaryBrush}"
                BorderThickness="0,0,1,0">
                <ctrl:Sidebar
                    x:Name="SideNav"
                    Width="180"
                    Margin="5"
                    Background="Transparent"
                    SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <!--  主操作台  -->
                    <ctrl:SidebarItem Header="过磅操作" Tag="WeighingView">
                        <ctrl:SidebarItem.Icon>
                            <pf:PackIcon
                                Width="20"
                                Height="20"
                                Kind="MonitorDashboard" />
                        </ctrl:SidebarItem.Icon>
                    </ctrl:SidebarItem>

                    <!--  数据统计  -->
                    <ctrl:SidebarItem Header="数据统计" Tag="StatisticsView">
                        <ctrl:SidebarItem.Icon>
                            <pf:PackIcon
                                Width="18"
                                Height="18"
                                Kind="ChartBar" />
                        </ctrl:SidebarItem.Icon>
                    </ctrl:SidebarItem>

                    <!--  综合管理（Admin）  -->
                    <ctrl:SidebarItem
                        Header="综合管理"
                        Tag="BasicDataView"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ctrl:SidebarItem.Icon>
                            <pf:PackIcon
                                Width="18"
                                Height="18"
                                Kind="ClipboardListOutline" />
                        </ctrl:SidebarItem.Icon>
                    </ctrl:SidebarItem>

                    <!--  参数管理（Admin）  -->
                    <ctrl:SidebarItem
                        Header="参数管理"
                        Tag="ParameterManageView"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ctrl:SidebarItem.Icon>
                            <pf:PackIcon
                                Width="18"
                                Height="18"
                                Kind="Tune" />
                        </ctrl:SidebarItem.Icon>
                    </ctrl:SidebarItem>

                    <!--  用户管理（Admin）  -->
                    <ctrl:SidebarItem
                        Header="用户管理"
                        Tag="UserManageView"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ctrl:SidebarItem.Icon>
                            <pf:PackIcon
                                Width="18"
                                Height="18"
                                Kind="AccountCog" />
                        </ctrl:SidebarItem.Icon>
                    </ctrl:SidebarItem>

                    <!--  云同步（Admin，暂未启用）  -->
                    <ctrl:SidebarItem
                        Header="云同步"
                        IsEnabled="False"
                        Tag="CloudSyncView"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ctrl:SidebarItem.Icon>
                            <pf:PackIcon
                                Width="18"
                                Height="18"
                                Kind="CloudSync" />
                        </ctrl:SidebarItem.Icon>
                    </ctrl:SidebarItem>
                </ctrl:Sidebar>
            </Border>

            <!--  右侧内容区（页面切换过渡动画）  -->
            <pf:TransitioningContentControl
                Grid.Column="1"
                prism:RegionManager.RegionName="{x:Static shell:RegionNames.Main}"
                TransitionMode="Right2LeftWithFade"
                TransitionStoryboard="{StaticResource Right2LeftWithFadeTransition}" />
        </Grid>

        <!--  ══ 日志面板（滑入/滑出动画） ══  -->
        <Border
            Grid.Row="1"
            Background="{DynamicResource WindowBrush}"
            BorderBrush="{DynamicResource PrimaryBrush}"
            BorderThickness="0,1,0,0"
            ClipToBounds="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="MaxHeight" Value="0" />
                    <Setter Property="Opacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLogPanelOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="MaxHeight"
                                            To="180"
                                            Duration="0:0:0.28">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="MaxHeight"
                                            To="0"
                                            Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid Height="180">
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  日志头部  -->
                <Border
                    Grid.Row="0"
                    Padding="8,0"
                    Background="{DynamicResource RegionBrush}">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <pf:PackIcon
                                Width="14"
                                Height="14"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource SecondaryTextBrush}"
                                Kind="TextBoxOutline" />
                            <TextBlock
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource SecondaryTextBrush}"
                                Text="系统日志" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource SecondaryTextBrush}">
                                <Run Text="{Binding LogEntries.Count, Mode=OneWay}" />
                                <Run Text=" 条" />
                            </TextBlock>
                        </StackPanel>
                        <Button
                            Height="20"
                            Padding="8,0"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="1"
                            Command="{Binding ClearLogCommand}"
                            Content="清空"
                            FontSize="10"
                            Foreground="{DynamicResource SecondaryTextBrush}" />
                    </Grid>
                </Border>

                <!--  日志条目列表  -->
                <ScrollViewer
                    x:Name="LogScrollViewer"
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="LogItemsControl" ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />   
                                        <!--  时间  -->
                                        <ColumnDefinition Width="36" />   
                                        <!--  级别  -->
                                        <ColumnDefinition Width="*" />    
                                        <!--  消息  -->
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        FontFamily="Consolas"
                                        FontSize="10"
                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                        Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" />

                                    <TextBlock
                                        Grid.Column="1"
                                        FontFamily="Consolas"
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Text="{Binding LevelTag}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4CAF50" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warn">
                                                        <Setter Property="Foreground" Value="#FF9800" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                        <Setter Property="Foreground" Value="#F44336" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock
                                        Grid.Column="2"
                                        FontSize="10"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                        <Setter Property="Foreground" Value="#F44336" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warn">
                                                        <Setter Property="Foreground" Value="#FF9800" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="{Binding Source, StringFormat='[{0}] ', Mode=OneWay}" />
                                        <Run Text="{Binding Message, Mode=OneWay}" />
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!--  状态栏  -->
        <StatusBar Grid.Row="2" Background="{DynamicResource RegionBrush}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse
                        Width="8"
                        Height="8"
                        Margin="0,0,4,0"
                        Fill="{Binding SerialPortStatusBrush}" />
                    <TextBlock Foreground="{Binding SerialPortStatusBrush}" Text="{Binding SerialPortStatusText}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Foreground="{DynamicResource SecondaryTextBrush}" Text="当前用户：" />
                    <Run Text="{Binding CurrentUserDisplay, Mode=OneWay}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Button
                        Height="22"
                        Margin="0,0,8,0"
                        Padding="8,0"
                        Background="Transparent"
                        BorderThickness="1"
                        Command="{Binding ToggleLogPanelCommand}"
                        FontSize="10"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        ToolTip="展开/收起日志面板">
                        <StackPanel Orientation="Horizontal">
                            <pf:PackIcon
                                Width="12"
                                Height="12"
                                VerticalAlignment="Center"
                                Kind="TextBoxOutline" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="10"
                                Text=" 日志" />
                        </StackPanel>
                    </Button>
                    <TextBlock VerticalAlignment="Center" Text="{Binding SystemTime}" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{Binding ClosingCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
</pf:Window>
