<pf:Window
    x:Class="AWS.Shell.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    Title="登录"
    Width="420" Height="340"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    ShowNonClientArea="True"
    NonClientAreaHeight="36"
    Style="{StaticResource WindowWin10}">

    <pf:Window.NonClientAreaContent>
        <TextBlock VerticalAlignment="Center" Margin="12,0"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Text="绿鑫资源 — 智能过磅系统" />
    </pf:Window.NonClientAreaContent>

    <Grid Margin="48,24,48,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="欢迎登录"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   HorizontalAlignment="Center" />

        <TextBlock Grid.Row="2" Text="用户名"
                   Foreground="{DynamicResource SecondaryTextBrush}" />
        <TextBox Grid.Row="4" x:Name="TxtUsername"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="6" Text="密码"
                   Foreground="{DynamicResource SecondaryTextBrush}" />
        <PasswordBox Grid.Row="8" x:Name="PwdBox"
                     PasswordChanged="PwdBox_PasswordChanged" />

        <TextBlock Grid.Row="10"
                   Foreground="{DynamicResource DangerBrush}"
                   Text="{Binding ErrorMessage}"
                   Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Button Grid.Row="12" Content="登 录"
                Command="{Binding LoginCommand}"
                Style="{StaticResource ButtonPrimary}"
                Height="36" />
    </Grid>
</pf:Window>
