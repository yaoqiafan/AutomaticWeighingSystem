<Window
    x:Class="AWS.Shell.Views.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AWS.Shell.Views"
    x:Name="Root"
    Width="800"
    Height="460"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    Loaded="OnLoaded">

    <Window.Resources>
        <local:SplashMsgBrushConverter x:Key="MsgBrush" />
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!--  整体淡入  -->
                    <DoubleAnimation
                        Storyboard.TargetName="Card"
                        Storyboard.TargetProperty="Opacity"
                        From="0"
                        To="1"
                        Duration="0:0:0.6" />

                    <!--  进度条彗星扫描（循环）  -->
                    <DoubleAnimation
                        Storyboard.TargetName="BarTranslate"
                        Storyboard.TargetProperty="X"
                        BeginTime="0:0:0.3"
                        From="-220"
                        RepeatBehavior="Forever"
                        To="800"
                        Duration="0:0:1.8" />

                    <!--  三点脉冲（错开相位）  -->
                    <DoubleAnimation
                        Storyboard.TargetName="Dot1"
                        Storyboard.TargetProperty="Opacity"
                        AutoReverse="True"
                        BeginTime="0:0:0"
                        From="1"
                        RepeatBehavior="Forever"
                        To="0.15"
                        Duration="0:0:0.48" />
                    <DoubleAnimation
                        Storyboard.TargetName="Dot2"
                        Storyboard.TargetProperty="Opacity"
                        AutoReverse="True"
                        BeginTime="0:0:0.16"
                        From="1"
                        RepeatBehavior="Forever"
                        To="0.15"
                        Duration="0:0:0.48" />
                    <DoubleAnimation
                        Storyboard.TargetName="Dot3"
                        Storyboard.TargetProperty="Opacity"
                        AutoReverse="True"
                        BeginTime="0:0:0.32"
                        From="1"
                        RepeatBehavior="Forever"
                        To="0.15"
                        Duration="0:0:0.48" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!--  阴影包装层（留 Margin 使阴影可见）  -->
    <Border Margin="14">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="28"
                Direction="270"
                Opacity="0.55"
                RenderingBias="Performance"
                ShadowDepth="7"
                Color="#000000" />
        </Border.Effect>

        <!--  主卡片  -->
        <Border
            x:Name="Card"
            Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <!--  内容区  -->
                    <RowDefinition Height="3" />
                    <!--  进度条  -->
                    <RowDefinition Height="52" />
                    <!--  状态栏  -->
                </Grid.RowDefinitions>

                <!--  ═══ 内容区背景 ═══  -->
                <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" />

                <!--  ═══ 主内容 ═══  -->
                <StackPanel
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <!--  徽章  -->
                    <Grid
                        Width="76"
                        Height="76"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,22">
                        <!--  外圈光晕  -->
                        <Ellipse
                            Width="76"
                            Height="76"
                            Fill="{DynamicResource PrimaryBrush}"
                            Opacity="0.1" />
                        <!--  内圆  -->
                        <Ellipse
                            Width="60"
                            Height="60"
                            Fill="{DynamicResource DeepDarkPrimaryBrush}"
                            Stroke="{DynamicResource PrimaryBrush}"
                            StrokeThickness="1.5" />
                        <!--  文字  -->
                        <TextBlock
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{DynamicResource PrimaryBrush}"
                            HorizontalAlignment="Center"
                            Text="绿鑫"
                            VerticalAlignment="Center" />
                    </Grid>

                    <!--  系统主标题  -->
                    <TextBlock
                        FontSize="36"
                        FontWeight="Bold"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,10"
                        Text="称重管理系统"
                        TextOptions.TextRenderingMode="ClearType" />

                    <!--  英文副标题  -->
                    <TextBlock
                        FontSize="13"
                        Foreground="{DynamicResource ThirdlyTextBrush}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,22"
                        Text="Intelligent Weighing Management System" />

                    <!--  版本标签  -->
                    <Border
                        HorizontalAlignment="Center"
                        Background="{DynamicResource DeepDarkPrimaryBrush}"
                        BorderBrush="{DynamicResource PrimaryBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18,5"
                        Opacity="0.9">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource LightPrimaryBrush}"
                            Text="v 1.0" />
                    </Border>
                </StackPanel>

                <!--  ═══ 进度条（彗星式扫描）═══  -->
                <Canvas
                    Grid.Row="1"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    ClipToBounds="True">
                    <Rectangle Height="3" Width="220">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0" Color="Transparent" />
                                <GradientStop Offset="0.3" Color="#02AD8B" />
                                <GradientStop Offset="0.7" Color="#3BD9B6" />
                                <GradientStop Offset="1" Color="Transparent" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.RenderTransform>
                            <TranslateTransform x:Name="BarTranslate" X="-220" />
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Canvas>

                <!--  ═══ 状态栏 ═══  -->
                <Border
                    Grid.Row="2"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource SecondaryBorderBrush}"
                    BorderThickness="0,1,0,0">
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  三点脉冲  -->
                        <StackPanel
                            Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                            <Ellipse
                                x:Name="Dot1"
                                Width="6"
                                Height="6"
                                Margin="0,0,6,0"
                                Fill="{DynamicResource PrimaryBrush}" />
                            <Ellipse
                                x:Name="Dot2"
                                Width="6"
                                Height="6"
                                Margin="0,0,6,0"
                                Fill="{DynamicResource PrimaryBrush}" />
                            <Ellipse
                                x:Name="Dot3"
                                Width="6"
                                Height="6"
                                Fill="{DynamicResource PrimaryBrush}" />
                        </StackPanel>

                        <!--  状态文字  -->
                        <TextBlock
                            Grid.Column="2"
                            FontSize="12"
                            Foreground="{Binding StatusType, ElementName=Root, Converter={StaticResource MsgBrush}}"
                            Text="{Binding StatusMessage, ElementName=Root}"
                            VerticalAlignment="Center" />

                        <!--  版权  -->
                        <TextBlock
                            Grid.Column="3"
                            FontSize="11"
                            Foreground="{DynamicResource ThirdlyTextBrush}"
                            Opacity="0.5"
                            Text="© 2025 绿鑫资源"
                            VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
