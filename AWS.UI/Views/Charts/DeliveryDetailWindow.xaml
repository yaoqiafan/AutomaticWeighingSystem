<pf:Window x:Class="AWS.UI.Views.Charts.DeliveryDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
        Title="送货记录详情" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <pf:Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="HeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
            <Setter Property="FontSize" Value="11" />
        </Style>
    </pf:Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ① 基本信息 -->
        <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="送货单" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                           Text="{Binding TicketNo}" Style="{StaticResource ValueStyle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryBrush}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="客户" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CustomerName}" Style="{StaticResource ValueStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="送货时间" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="3"
                           Text="{Binding DeliveryTime, StringFormat='HH:mm:ss'}"
                           Style="{StaticResource ValueStyle}" />
            </Grid>
        </Border>

        <!-- ② 货物明细 -->
        <Border Grid.Row="2" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="12,10">
            <StackPanel>
                <TextBlock Text="货物明细" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" />
                <!-- 表头 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="品类" Style="{StaticResource HeaderStyle}" />
                    <TextBlock Grid.Column="1" Text="重量 (kg)" Style="{StaticResource HeaderStyle}" TextAlignment="Right" />
                    <TextBlock Grid.Column="2" Text="单价" Style="{StaticResource HeaderStyle}" TextAlignment="Right" />
                    <TextBlock Grid.Column="3" Text="金额 (元)" Style="{StaticResource HeaderStyle}" TextAlignment="Right" />
                </Grid>
                <Separator Margin="0,4,0,4" Opacity="0.3" />
                <!-- 明细行 -->
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding GoodsName}"
                                           Style="{StaticResource ValueStyle}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Weight, StringFormat='{}{0:N1}'}"
                                           Style="{StaticResource ValueStyle}" TextAlignment="Right" />
                                <TextBlock Grid.Column="2" TextAlignment="Right">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ValueStyle}">
                                            <Setter Property="TextAlignment" Value="Right" />
                                            <Setter Property="Text" Value="{Binding PricePerUnit, StringFormat='{}{0:F4}'}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PricePerUnit}" Value="{x:Null}">
                                                    <Setter Property="Text" Value="—" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="3" TextAlignment="Right">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ValueStyle}">
                                            <Setter Property="TextAlignment" Value="Right" />
                                            <Setter Property="Text" Value="{Binding Amount, StringFormat='{}{0:N2}'}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Amount}" Value="{x:Null}">
                                                    <Setter Property="Text" Value="—" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ③ 汇总 -->
        <Border Grid.Row="4" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="总重量" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Column="1" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="#4CAF50">
                    <Run Text="{Binding TotalWeight, StringFormat='{}{0:N1}', Mode=OneWay}" />
                    <Run Text=" kg" FontSize="11" />
                </TextBlock>

                <TextBlock Grid.Column="2" Text="总金额" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Column="3" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="#4CAF50">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{Binding TotalAmount, StringFormat='¥ {0:N2}'}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TotalAmount}" Value="{x:Null}">
                                    <Setter Property="Text" Value="—" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ④ 关闭按钮 -->
        <Button Grid.Row="6" Content="关  闭" Height="38" FontSize="13"
                Click="OnClose" HorizontalAlignment="Stretch" />
    </Grid>
</pf:Window>
