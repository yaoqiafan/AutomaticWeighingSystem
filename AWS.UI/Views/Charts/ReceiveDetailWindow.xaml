<pf:Window x:Class="AWS.UI.Views.Charts.ReceiveDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
        xmlns:conv="clr-namespace:AWS.UI.Converters"
        Title="收货记录详情" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <pf:Window.Resources>
        <conv:PathToUriConverter x:Key="PathToUri" />
        <conv:ImagePathToVisibilityConverter x:Key="ImagePathToVisibility" />

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </pf:Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ① 基本信息 -->
        <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="磅单号" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                           Text="{Binding TicketNo}" Style="{StaticResource ValueStyle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryBrush}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="车牌号" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="1">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource ValueStyle}">
                            <Setter Property="Text" Value="{Binding VehiclePlate}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding VehiclePlate}" Value="{x:Null}">
                                    <Setter Property="Text" Value="—" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="货物" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding GoodsName}" Style="{StaticResource ValueStyle}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="客户" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                           Text="{Binding CustomerName}" Style="{StaticResource ValueStyle}" />
            </Grid>
        </Border>

        <!-- ② 称重时间 -->
        <Border Grid.Row="2" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="首次过磅" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding FirstWeighTime, StringFormat='HH:mm:ss'}"
                           Style="{StaticResource ValueStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="重量" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource ValueStyle}">
                    <Run Text="{Binding FirstWeight, StringFormat='{}{0:N1}', Mode=OneWay}" />
                    <Run Text=" kg" />
                </TextBlock>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="二次过磅" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding SecondWeighTime, StringFormat='HH:mm:ss'}"
                           Style="{StaticResource ValueStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="重量" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="3" Style="{StaticResource ValueStyle}">
                    <Run Text="{Binding SecondWeight, StringFormat='{}{0:N1}', Mode=OneWay}" />
                    <Run Text=" kg" />
                </TextBlock>
            </Grid>
        </Border>

        <!-- ③ 毛/皮/净 + 金额 -->
        <Border Grid.Row="4" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 毛/皮/净 -->
                <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="毛 重" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />
                    <TextBlock FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}">
                        <Run Text="{Binding GrossWeight, StringFormat='{}{0:N1}', Mode=OneWay}" />
                        <Run Text=" kg" FontSize="11" />
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="皮 重" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />
                    <TextBlock FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}">
                        <Run Text="{Binding TareWeight, StringFormat='{}{0:N1}', Mode=OneWay}" />
                        <Run Text=" kg" FontSize="11" />
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="净 重" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center" />
                    <TextBlock FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#4CAF50">
                        <Run Text="{Binding NetWeight, StringFormat='{}{0:N1}', Mode=OneWay}" />
                        <Run Text=" kg" FontSize="11" />
                    </TextBlock>
                </StackPanel>

                <!-- 单价 / 金额 -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                    <TextBlock Text="单价：" Style="{StaticResource LabelStyle}" />
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ValueStyle}">
                                <Setter Property="Text" Value="{Binding PricePerUnit, StringFormat='{}{0:F4} 元/kg'}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PricePerUnit}" Value="{x:Null}">
                                        <Setter Property="Text" Value="—" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="   合计：" Style="{StaticResource LabelStyle}" />
                    <TextBlock FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="#4CAF50">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding TotalAmount, StringFormat='¥ {0:N2}'}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TotalAmount}" Value="{x:Null}">
                                        <Setter Property="Text" Value="—" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ④ 操作员 / 归档时间 -->
        <Border Grid.Row="6" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="操作员" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Column="1" Text="{Binding OperatorName}" Style="{StaticResource ValueStyle}" />
                <TextBlock Grid.Column="2" Text="归档时间" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Column="3"
                           Text="{Binding ArchivedAt, StringFormat='HH:mm:ss'}"
                           Style="{StaticResource ValueStyle}" />
            </Grid>
        </Border>

        <!-- ⑤ 过磅图像 -->
        <Border Grid.Row="8" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="12,10">
            <StackPanel>

                <!-- 首次过磅图像 -->
                <TextBlock Text="首次过磅图像" Style="{StaticResource LabelStyle}" Margin="0,0,0,6" />
                <Grid Height="220">
                    <pf:ImageViewer
                        Uri="{Binding FirstWeighImagePath, Converter={StaticResource PathToUri}}"
                        ShowToolBar="True"
                        ShowImgMap="False"
                        Visibility="{Binding FirstWeighImagePath, Converter={StaticResource ImagePathToVisibility}}" />
                    <Border CornerRadius="4" BorderThickness="1"
                            BorderBrush="{DynamicResource SecondaryTextBrush}"
                            Opacity="0.45"
                            Visibility="{Binding FirstWeighImagePath, Converter={StaticResource ImagePathToVisibility}, ConverterParameter=Invert}">
                        <TextBlock Text="暂无图片"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                    </Border>
                </Grid>

                <!-- 二次过磅图像 -->
                <TextBlock Text="二次过磅图像" Style="{StaticResource LabelStyle}" Margin="0,12,0,6" />
                <Grid Height="220">
                    <pf:ImageViewer
                        Uri="{Binding SecondWeighImagePath, Converter={StaticResource PathToUri}}"
                        ShowToolBar="True"
                        ShowImgMap="False"
                        Visibility="{Binding SecondWeighImagePath, Converter={StaticResource ImagePathToVisibility}}" />
                    <Border CornerRadius="4" BorderThickness="1"
                            BorderBrush="{DynamicResource SecondaryTextBrush}"
                            Opacity="0.45"
                            Visibility="{Binding SecondWeighImagePath, Converter={StaticResource ImagePathToVisibility}, ConverterParameter=Invert}">
                        <TextBlock Text="暂无图片"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                    </Border>
                </Grid>

            </StackPanel>
        </Border>

        <!-- ⑥ 关闭按钮 -->
        <Button Grid.Row="10" Content="关  闭" Height="38" FontSize="13"
                Click="OnClose" HorizontalAlignment="Stretch" />
    </Grid>
</pf:Window>
