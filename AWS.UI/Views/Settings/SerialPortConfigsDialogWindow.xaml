<pf:Window x:Class="AWS.UI.Views.Settings.SerialPortConfigsDialogWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:sys="clr-namespace:System;assembly=mscorlib"
           xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
           Title="串口设备配置"
           Width="660" Height="420"
           WindowStartupLocation="CenterOwner"
           ResizeMode="NoResize"
           ShowInTaskbar="False"
           ShowNonClientArea="False">

    <pf:Window.Resources>
        <x:Array x:Key="BaudRateOptions" Type="sys:Int32">
            <sys:Int32>2400</sys:Int32>
            <sys:Int32>4800</sys:Int32>
            <sys:Int32>9600</sys:Int32>
            <sys:Int32>19200</sys:Int32>
            <sys:Int32>38400</sys:Int32>
        </x:Array>
    </pf:Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 设备列表 -->
        <DataGrid Grid.Row="0"
                  x:Name="DeviceGrid"
                  ItemsSource="{Binding Devices}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"

                  SelectionMode="Single"

                  BorderThickness="1">

            <DataGrid.Columns>

                <!-- 启用 -->
                <DataGridTemplateColumn Header="启用" Width="48">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 模拟模式 -->
                <DataGridTemplateColumn Header="模拟" Width="52">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSimulationMode, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      ToolTip="启用后使用软件模拟数据，不实际连接串口" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 串口名称 -->
                <DataGridTemplateColumn Header="串口名称" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox IsEditable="True"
                                      Text="{Binding PortName, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding DataContext.AvailablePorts,
                                          RelativeSource={RelativeSource AncestorType=pf:Window}}"
                                      Margin="2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 波特率 -->
                <DataGridTemplateColumn Header="波特率" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox SelectedValue="{Binding BaudRate, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{StaticResource BaudRateOptions}"
                                      Margin="2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 称重用途 -->
                <DataGridTemplateColumn Header="称重用途" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox SelectedValue="{Binding WeighModeDisplay, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding DataContext.WeighModeOptions,
                                          RelativeSource={RelativeSource AncestorType=pf:Window}}"
                                      Margin="2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 删除 -->
                <DataGridTemplateColumn Header="" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✕"
                                    Width="28" Height="24"
                                    FontSize="11"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#EF5350"
                                    Command="{Binding DataContext.RemoveCommand,
                                        RelativeSource={RelativeSource AncestorType=pf:Window}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- 添加按钮 -->
        <Button Grid.Row="1"
                Content="＋ 添加设备"
                HorizontalAlignment="Left"
                Width="110" Height="30"
                Margin="0,8,0,0"
                Command="{Binding AddCommand}" />

        <!-- 确定 / 取消 -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="取消"
                    Width="72" Height="30"
                    Margin="0,0,8,0"
                    Click="OnCancelClick"
                    Background="Transparent"
                    BorderThickness="1" />
            <Button Content="确定"
                    Width="72" Height="30"
                    Click="OnOkClick"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0" />
        </StackPanel>
    </Grid>

</pf:Window>
