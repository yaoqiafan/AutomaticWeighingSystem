<UserControl x:Class="AWS.UI.Views.Settings.ParameterManageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <pf:PackIcon Kind="Tune" Width="18" Height="18"
                                 Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="参数管理" Margin="6,0,0,0"
                               FontSize="{DynamicResource FontSize.H2.Title}" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" />
                   
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="重载" Width="72" Height="30" Margin="0,0,8,0"
                            Command="{Binding ReloadCommand}"
                            Background="Transparent" BorderThickness="1" />
                    <Button Content="保存" Width="72" Height="30"
                            Command="{Binding SaveCommand}"
                            Background="#4CAF50" Foreground="White" BorderThickness="0" />
                </StackPanel>
            </DockPanel>
        </Border>



        <Grid Grid.Row="1" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- PropertyGrid：绑定 SystemParameters POCO，自动反射所有可浏览属性 -->
            <pf:Card Grid.Column="1" Height="auto" Background="{DynamicResource RegionBrush}" Margin="45"  pf:BorderElement.CornerRadius="20" >
                <pf:PropertyGrid SelectedObject="{Binding Parameters}" Margin="5" 
                      ShowSortButton="True"
                      MinTitleWidth="120"
                      MaxTitleWidth="200" />
            </pf:Card>
        </Grid>
        
       
    </Grid>
</UserControl>
