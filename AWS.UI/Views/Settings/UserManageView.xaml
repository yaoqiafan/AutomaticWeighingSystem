<UserControl
    x:Class="AWS.UI.Views.Settings.UserManageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:AWS.UI.Converters"
    xmlns:local="clr-namespace:AWS.UI.Views.Settings"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <local:BindingProxy x:Key="Proxy" Data="{Binding}" />
        <conv:UserRoleToBrushConverter x:Key="RoleToBrush" />
        <conv:UserRoleToDisplayConverter x:Key="RoleToDisplay" />
        <conv:UserRoleToIconConverter x:Key="RoleToIcon" />
        <conv:BoolToActiveTextConverter x:Key="ActiveText" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部操作栏  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,8"
            Padding="12,8"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <pf:PackIcon
                        Width="18"
                        Height="18"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Kind="AccountGroupOutline" />
                    <TextBlock
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSize.H2.Title}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Text="权限管理" />
                    <TextBlock
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{DynamicResource SecondaryTextBrush}">
                        <Run Text="共 " /><Run Text="{Binding Users.Count, Mode=OneWay}" /><Run Text=" 个用户" />
                    </TextBlock>
                </StackPanel>
                <StackPanel
                    DockPanel.Dock="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding LoadUsersCommand}"
                        Content="刷新" />
                    <Button
                        Command="{Binding AddCommand}"
                        Content="＋ 新增用户"
                        Style="{StaticResource ButtonPrimary}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  用户卡片列表  -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <pf:CoverView
                ItemContentHeight="280"
                ItemContentHeightFixed="True"
                ItemHeight="220"
                ItemsSource="{Binding Users}"
                ItemWidth="190">

                <!--  ══ 卡片封面 ══  -->
                <pf:CoverView.ItemHeaderTemplate>
                    <DataTemplate>
                        <Border
                            Margin="6"
                            Background="{DynamicResource RegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Cursor="Hand">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Opacity="0.08"
                                    ShadowDepth="2"
                                    Color="#000000" />
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <!--  头像  -->
                                    <RowDefinition Height="Auto" />
                                    <!--  用户名  -->
                                    <RowDefinition Height="Auto" />
                                    <!--  角色徽章  -->
                                    <RowDefinition Height="Auto" />
                                    <!--  状态  -->
                                    <RowDefinition Height="1" />
                                    <!--  分隔  -->
                                    <RowDefinition Height="36" />
                                    <!--  提示  -->
                                </Grid.RowDefinitions>

                                <!--  头像圆形  -->
                                <Grid Grid.Row="0" Margin="0,18,0,8">
                                    <Ellipse
                                        Width="72"
                                        Height="72"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Fill="{Binding Role, Converter={StaticResource RoleToBrush}}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="28"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding Role, Converter={StaticResource RoleToIcon}}" />
                                </Grid>

                                <!--  用户名  -->
                                <TextBlock
                                    Grid.Row="1"
                                    Margin="10,0,10,4"
                                    HorizontalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="{Binding Username}"
                                    TextTrimming="CharacterEllipsis" />

                                <!--  角色徽章  -->
                                <Border
                                    Grid.Row="2"
                                    Margin="0,0,0,4"
                                    Padding="12,3"
                                    HorizontalAlignment="Center"
                                    Background="{Binding Role, Converter={StaticResource RoleToBrush}}"
                                    CornerRadius="10">
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="Medium"
                                        Foreground="White"
                                        Text="{Binding Role, Converter={StaticResource RoleToDisplay}}" />
                                </Border>

                                <!--  账号状态  -->
                                <TextBlock
                                    Grid.Row="3"
                                    Margin="0,0,0,8"
                                    HorizontalAlignment="Center"
                                    FontSize="10"
                                    Foreground="{DynamicResource SecondaryTextBrush}"
                                    Text="{Binding IsActive, Converter={StaticResource ActiveText}}" />

                                <!--  分隔线  -->
                                <Rectangle
                                    Grid.Row="4"
                                    Margin="12,0"
                                    Fill="{DynamicResource BorderBrush}" />

                                <!--  底部提示  -->
                                <TextBlock
                                    Grid.Row="5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{DynamicResource SecondaryTextBrush}"
                                    Text="点击展开编辑" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </pf:CoverView.ItemHeaderTemplate>

                <!--  ══ 展开编辑面板 ══  -->
                <pf:CoverView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="24,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <!--  label row  -->
                                <RowDefinition Height="Auto" />
                                <!--  input row  -->
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <!--  label row  -->
                                <RowDefinition Height="Auto" />
                                <!--  input row  -->
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <!--  启用 checkbox  -->
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <!--  buttons  -->
                            </Grid.RowDefinitions>

                            <!--  用户名  -->
                            <TextBlock
                                Grid.Row="0" Grid.Column="0"
                                Margin="0,0,0,4"
                                FontWeight="Medium"
                                Text="用户名" />
                            <TextBox
                                Grid.Row="1" Grid.Column="0"
                                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  密码（留空不修改）  -->
                            <TextBlock
                                Grid.Row="0" Grid.Column="2"
                                Margin="0,0,0,4"
                                FontWeight="Medium"
                                Text="密码（留空不修改）" />
                            <TextBox
                                Grid.Row="1" Grid.Column="2"
                                Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  权限等级  -->
                            <TextBlock
                                Grid.Row="3" Grid.Column="0"
                                Margin="0,0,0,4"
                                FontWeight="Medium"
                                Text="权限等级" />
                            <ComboBox
                                Grid.Row="4" Grid.Column="0"
                                ItemsSource="{Binding Data.AvailableRoles, Source={StaticResource Proxy}}"
                                SelectedItem="{Binding Role, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource RoleToDisplay}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!--  创建时间（只读）  -->
                            <TextBlock
                                Grid.Row="3" Grid.Column="2"
                                Margin="0,0,0,4"
                                FontWeight="Medium"
                                Text="创建时间" />
                            <TextBlock
                                Grid.Row="4" Grid.Column="2"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{DynamicResource SecondaryTextBrush}"
                                Text="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" />

                            <!--  启用状态（新用户默认启用，无需显示）  -->
                            <CheckBox
                                Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                                Content="账号启用"
                                IsChecked="{Binding IsActive}" />

                            <!--  操作按钮  -->
                            <StackPanel
                                Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,8,0"
                                    Command="{Binding Data.SaveUserCommand, Source={StaticResource Proxy}}"
                                    CommandParameter="{Binding}"
                                    Content="保存"
                                    Style="{StaticResource ButtonPrimary}" />
                                <Button
                                    Command="{Binding Data.DeleteCommand, Source={StaticResource Proxy}}"
                                    CommandParameter="{Binding}"
                                    Content="删除"
                                    Style="{StaticResource ButtonDashedDanger}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </pf:CoverView.ItemTemplate>
            </pf:CoverView>
        </ScrollViewer>
    </Grid>
</UserControl>
