<UserControl
    x:Class="AWS.UI.Views.Statistics.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:charts="clr-namespace:AWS.UI.Charts"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  5 卡片  -->
            <RowDefinition Height="240" />
            <!--  今日趋势图  -->
            <RowDefinition Height="*" />
            <!--  今日明细  -->
        </Grid.RowDefinitions>

        <!--  ═══ 5 张统计卡片 + 刷新 ═══  -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  今日收货净重（蓝）  -->
            <Border
                Grid.Column="0"
                Padding="16,12"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon
                            Width="14"
                            Height="14"
                            VerticalAlignment="Center"
                            Foreground="#2196F3"
                            Kind="Download" />
                        <TextBlock
                            Margin="5,0,0,0"
                            Style="{StaticResource CardLabel}"
                            Text="今日收货净重" />
                    </StackPanel>
                    <TextBlock
                        Foreground="#2196F3"
                        Style="{StaticResource CardValue}"
                        Text="{Binding TodayReceiveWeight}" />
                </StackPanel>
            </Border>

            <!--  今日送货重量（绿）  -->
            <Border
                Grid.Column="2"
                Padding="16,12"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon
                            Width="14"
                            Height="14"
                            VerticalAlignment="Center"
                            Foreground="#4CAF50"
                            Kind="Upload" />
                        <TextBlock
                            Margin="5,0,0,0"
                            Style="{StaticResource CardLabel}"
                            Text="今日送货重量" />
                    </StackPanel>
                    <TextBlock
                        Foreground="#4CAF50"
                        Style="{StaticResource CardValue}"
                        Text="{Binding TodayDeliveryWeight}" />
                </StackPanel>
            </Border>

            <!--  当前库存（紫） — 点击查看趋势  -->
            <Border
                Grid.Column="4"
                Padding="16,12"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="10"
                Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding Command="{Binding ShowInventoryTrendCommand}" MouseAction="LeftClick" />
                </Border.InputBindings>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon
                            Width="14"
                            Height="14"
                            VerticalAlignment="Center"
                            Foreground="#9C27B0"
                            Kind="Warehouse" />
                        <TextBlock
                            Margin="5,0,0,0"
                            Style="{StaticResource CardLabel}"
                            Text="当前总库存" />
                        <pf:PackIcon
                            Width="11"
                            Height="11"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="#9C27B0"
                            Kind="ChartLine" />
                    </StackPanel>
                    <TextBlock
                        Foreground="#9C27B0"
                        Style="{StaticResource CardValue}"
                        Text="{Binding CurrentInventory}" />
                    <TextBlock
                        Margin="0,3,0,0"
                        FontSize="10"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        Text="点击查看库存趋势 ▶" />
                </StackPanel>
            </Border>

            <!--  今日支出（橙）  -->
            <Border
                Grid.Column="6"
                Padding="16,12"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon
                            Width="14"
                            Height="14"
                            VerticalAlignment="Center"
                            Foreground="#FF9800"
                            Kind="CurrencyUsdOff" />
                        <TextBlock
                            Margin="5,0,0,0"
                            Style="{StaticResource CardLabel}"
                            Text="今日支出" />
                    </StackPanel>
                    <TextBlock
                        Foreground="#FF9800"
                        Style="{StaticResource CardValue}"
                        Text="{Binding TodayExpenditure}" />
                </StackPanel>
            </Border>

            <!--  今日收入（深绿）  -->
            <Border
                Grid.Column="8"
                Padding="16,12"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon
                            Width="14"
                            Height="14"
                            VerticalAlignment="Center"
                            Foreground="#2E7D32"
                            Kind="CurrencyUsd" />
                        <TextBlock
                            Margin="5,0,0,0"
                            Style="{StaticResource CardLabel}"
                            Text="今日收入" />
                    </StackPanel>
                    <TextBlock
                        Foreground="#2E7D32"
                        Style="{StaticResource CardValue}"
                        Text="{Binding TodayIncome}" />
                </StackPanel>
            </Border>

            <!--  刷新  -->
            <StackPanel
                Grid.Column="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
                <Button Command="{Binding RefreshCommand}" Content="刷新" />
                <TextBlock
                    Margin="0,5,0,0"
                    HorizontalAlignment="Center"
                    FontSize="10"
                    Foreground="{DynamicResource SecondaryTextBrush}">
                    <Run Text="更新 " /><Run Text="{Binding LastRefreshTime, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </Grid>

        <!--  ═══ 今日收发双折线图（全宽） ═══  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,8"
            Padding="10,8"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <pf:PackIcon
                        Width="14"
                        Height="14"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Kind="ChartLine" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSize.Body.Standard}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Text="今日每小时净重（按品类 / 浅灰=汇总 / 绿=送货）" />
                </StackPanel>
                <lvc:CartesianChart
                    Grid.Row="1"
                    Background="Transparent"
                    ChartPointPointerDownCommand="{Binding ChartPointDownCommand}"
                    LegendPosition="Hidden"
                    LegendTextPaint="{x:Static charts:ChartPaints.TooltipText}"
                    Series="{Binding HourlySeries}"
                    TooltipPosition="Hidden"
                    XAxes="{Binding XAxes}"
                    YAxes="{Binding YAxes}"
                    ZoomMode="X" />
            </Grid>
        </Border>

        <!--  ═══ 今日明细 ═══  -->
        <Border
            Grid.Row="2"
            Padding="8"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  表头：Tab 切换 + 新建送货单  -->
                <DockPanel Grid.Row="0" Margin="2,0,2,6">
                    <Button
                        Height="28"
                        Padding="10,0"
                        Background="#388E3C"
                        BorderThickness="0"
                        Command="{Binding AddDeliveryCommand}"
                        Content="＋ 新建送货单"
                        DockPanel.Dock="Right"
                        Foreground="White" />
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <pf:PackIcon
                            Width="14"
                            Height="14"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource PrimaryBrush}"
                            Kind="ClipboardListOutline" />
                        <TextBlock
                            Margin="5,0,12,0"
                            VerticalAlignment="Center"
                            FontSize="{DynamicResource FontSize.Body.Standard}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource PrimaryBrush}"
                            Text="今日明细" />
                        <!--  Tab 切换按钮  -->
                        <Border
                            Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding SwitchToReceiveTabCommand}" Content="收货记录">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource TabBtn}" TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowDeliveryTab}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding SwitchToDeliveryTabCommand}" Content="送货记录">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource TabBtn}" TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowDeliveryTab}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>

                <!--  收货记录 DataGrid  -->
                <DataGrid
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    IsReadOnly="True"
                    ItemsSource="{Binding TodayReceiveRecords}"
                    MouseDoubleClick="OnReceiveRowDoubleClick"
                    SelectionMode="Single">
                    <DataGrid.Style>
                        <Style BasedOn="{StaticResource DataGrid.Small}" TargetType="DataGrid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowDeliveryTab}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding TicketNo}"
                            Header="磅单号" />
                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding VehiclePlate}"
                            Header="车牌" />
                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding CustomerName}"
                            Header="客户" />
                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding GoodsName}"
                            Header="货物" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding NetWeight, StringFormat=F1}"
                            Header="净重(kg)" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding ArchivedAt, StringFormat=HH:mm}"
                            Header="时间" />
                    </DataGrid.Columns>
                </DataGrid>

                <!--  送货记录 DataGrid  -->
                <DataGrid
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    IsReadOnly="True"
                    ItemsSource="{Binding TodayDeliveryRecords}"
                    MouseDoubleClick="OnDeliveryRowDoubleClick"
                    SelectionMode="Single">
                    <DataGrid.Style>
                        <Style BasedOn="{StaticResource DataGrid.Small}" TargetType="DataGrid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowDeliveryTab}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding TicketNo}"
                            Header="送货单号" />
                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding CustomerName}"
                            Header="客户" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding GoodsSummary}"
                            Header="货物" />
                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding TotalWeight, StringFormat=F1}"
                            Header="总重(kg)" />
                        <DataGridTextColumn
                            Width="Auto"
                            Binding="{Binding TotalAmount, StringFormat=F2}"
                            Header="收入(元)" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding DeliveryTime, StringFormat=HH:mm}"
                            Header="时间" />
                    </DataGrid.Columns>
                </DataGrid>

                <!--  分页条  -->
                <DockPanel Grid.Row="2" Margin="0,4,0,0">
                    <!--  收货分页  -->
                    <StackPanel
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowDeliveryTab}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Text="每页" />
                        <ComboBox
                            Width="60"
                            Height="24"
                            FontSize="11"
                            ItemsSource="{Binding AvailablePageSizes}"
                            SelectedItem="{Binding PageSize}" />
                        <TextBlock
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Text="条" />
                    </StackPanel>
                    <!--  送货分页  -->
                    <StackPanel
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowDeliveryTab}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Text="每页" />
                        <ComboBox
                            Width="60"
                            Height="24"
                            FontSize="11"
                            ItemsSource="{Binding AvailablePageSizes}"
                            SelectedItem="{Binding DeliveryPageSize}" />
                        <TextBlock
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Text="条" />
                    </StackPanel>

                    <pf:Pagination
                        Height="{DynamicResource DefaultControlHeight}"
                        Margin="5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        IsJumpEnabled="True">
                        <pf:Pagination.Style>
                            <Style TargetType="pf:Pagination">
                                <Setter Property="DataCountPerPage" Value="{Binding PageSize}" />
                                <Setter Property="MaxPageCount" Value="{Binding TotalPageCount}" />
                                <Setter Property="PageIndex" Value="{Binding PageIndex, Mode=TwoWay}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowDeliveryTab}" Value="True">
                                        <Setter Property="DataCountPerPage" Value="{Binding DeliveryPageSize}" />
                                        <Setter Property="MaxPageCount" Value="{Binding DeliveryTotalPageCount}" />
                                        <Setter Property="PageIndex" Value="{Binding DeliveryPageIndex, Mode=TwoWay}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </pf:Pagination.Style>
                    </pf:Pagination>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
