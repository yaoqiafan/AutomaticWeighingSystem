<UserControl
    x:Class="AWS.UI.Views.Statistics.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:charts="clr-namespace:AWS.UI.Charts"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  统计卡片行  -->
            <RowDefinition Height="3*" />
            <!--  折线图  -->
            <RowDefinition Height="2*" />
            <!--  今日明细  -->
        </Grid.RowDefinitions>

        <!--  ═══ 统计卡片 + 刷新 ═══  -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  今日合计净重（蓝）  -->
            <Border
                Grid.Column="0"
                Padding="20,16"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon
                            Width="16"
                            Height="16"
                            VerticalAlignment="Center"
                            Foreground="#2196F3"
                            Kind="Weight" />
                        <TextBlock
                            Margin="6,0,0,0"
                            Style="{StaticResource CardLabel}"
                            Text="今日合计净重" />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        Foreground="#2196F3"
                        Style="{StaticResource CardValue}"
                        Text="{Binding TodayTotalWeight}" />
                    <Rectangle
                        Grid.Row="2"
                        Width="36"
                        Height="3"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        Fill="#2196F3"
                        RadiusX="1.5"
                        RadiusY="1.5" />
                </Grid>
            </Border>

            <!--  今日车次（绿）  -->
            <Border
                Grid.Column="2"
                Padding="20,16"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon
                            Width="16"
                            Height="16"
                            VerticalAlignment="Center"
                            Foreground="#4CAF50"
                            Kind="TruckFast" />
                        <TextBlock
                            Margin="6,0,0,0"
                            Style="{StaticResource CardLabel}"
                            Text="今日车次" />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        Foreground="#4CAF50"
                        Style="{StaticResource CardValue}"
                        Text="{Binding TodayVehicleCount}" />
                    <Rectangle
                        Grid.Row="2"
                        Width="36"
                        Height="3"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        Fill="#4CAF50"
                        RadiusX="1.5"
                        RadiusY="1.5" />
                </Grid>
            </Border>

            <!--  今日金额（橙）  -->
            <Border
                Grid.Column="4"
                Padding="20,16"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon
                            Width="16"
                            Height="16"
                            VerticalAlignment="Center"
                            Foreground="#FF9800"
                            Kind="CurrencyUsd" />
                        <TextBlock
                            Margin="6,0,0,0"
                            Style="{StaticResource CardLabel}"
                            Text="今日金额" />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        Foreground="#FF9800"
                        Style="{StaticResource CardValue}"
                        Text="{Binding TodayTotalAmount}" />
                    <Rectangle
                        Grid.Row="2"
                        Width="36"
                        Height="3"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        Fill="#FF9800"
                        RadiusX="1.5"
                        RadiusY="1.5" />
                </Grid>
            </Border>

            <!--  刷新区域  -->
            <StackPanel
                Grid.Column="6"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
                <Button
                    
                    Command="{Binding RefreshCommand}"
                    Content="刷新" />
                <TextBlock
                    Margin="0,6,0,0"
                    HorizontalAlignment="Center"
                    FontSize="10"
                    Foreground="{DynamicResource SecondaryTextBrush}">
                    <Run Text="更新 " /><Run Text="{Binding LastRefreshTime, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </Grid>

        <!--  ═══ 今日每小时净重折线图 ═══  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,8"
            Padding="10,6"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <pf:PackIcon
                        Width="15"
                        Height="15"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Kind="ChartLine" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSize.Body.Standard}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Text="今日每小时净重趋势" />
                </StackPanel>
                <lvc:CartesianChart
                    Grid.Row="1"
                    LegendTextPaint="{x:Static charts:ChartPaints.TooltipText}"
                    Series="{Binding HourlySeries}"
                    TooltipTextPaint="{x:Static charts:ChartPaints.TooltipText}"
                    XAxes="{Binding XAxes}"
                    YAxes="{Binding YAxes}" />
            </Grid>
        </Border>

        <!--  ═══ 今日明细 ═══  -->
        <Border
            Grid.Row="2"
            Padding="8"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Margin="2,0,2,6"
                    Orientation="Horizontal">
                    <pf:PackIcon
                        Width="15"
                        Height="15"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Kind="ClipboardListOutline" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSize.Body.Standard}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Text="今日明细" />
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{DynamicResource SecondaryTextBrush}">
                        <Run Text="共 " /><Run Text="{Binding TodayVehicleCount, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>

                <DataGrid
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                  Style="{StaticResource DataGrid.Small}"
                    IsReadOnly="True"
                    ItemsSource="{Binding TodayRecords}"
                   
                    SelectionMode="Single">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader"  BasedOn="{StaticResource  DataGridColumnHeaderStyle.Small}">
                            <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="Padding" Value="6,0" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle > 
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle.Small}">
                            <Setter Property="Padding" Value="6,0" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                           
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="auto"
                            Binding="{Binding TicketNo}"
                            Header="磅单号" />
                        <DataGridTextColumn
                            Width="auto"
                            Binding="{Binding VehiclePlate}"
                            Header="车牌" />
                        <DataGridTextColumn
                            Width="auto"
                            Binding="{Binding CustomerName}"
                            Header="客户" />
                        <DataGridTextColumn
                            Width="auto"
                            Binding="{Binding GoodsName}"
                            Header="货物" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding NetWeight, StringFormat=F1}"
                            Header="净重(kg)" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding ArchivedAt, StringFormat=HH:mm}"
                            Header="存档时间" />
                    </DataGrid.Columns>
                </DataGrid>

                <!--  分页条  -->
                <DockPanel Grid.Row="2" Margin="0,4,0,0">
                    <StackPanel
                        DockPanel.Dock="Right"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Text="每页" />
                        <ComboBox
                            Width="60"
                            Height="24"
                            FontSize="11"
                            ItemsSource="{Binding AvailablePageSizes}"
                            SelectedItem="{Binding PageSize}" />
                        <TextBlock
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Text="条" />
                    </StackPanel>
                    <pf:Pagination Height="{DynamicResource DefaultControlHeight}" Margin="5" IsJumpEnabled="True"
                        HorizontalAlignment="Left"
                                   DataCountPerPage="{Binding PageSize}"
                        VerticalAlignment="Center"
                        MaxPageCount="{Binding TotalPageCount}"
                        PageIndex="{Binding PageIndex, Mode=TwoWay}" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
