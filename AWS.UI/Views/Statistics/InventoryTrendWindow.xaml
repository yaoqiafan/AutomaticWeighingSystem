<pf:Window
    x:Class="AWS.UI.Views.Statistics.InventoryTrendWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:charts="clr-namespace:AWS.UI.Charts"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    Title="库存趋势分析"
    Width="820" Height="560"
    MinWidth="600" MinHeight="400"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 筛选栏 -->
        <Border Grid.Row="0" Margin="0,0,0,10" Padding="12,8"
                Background="{DynamicResource RegionBrush}" CornerRadius="6">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="品类筛选：" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,6,0" />
                <ComboBox Width="130" Height="28" Margin="0,0,20,0"
                          ItemsSource="{Binding InventoryCategories}"
                          SelectedItem="{Binding SelectedInventoryCategory}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ., TargetNullValue='全部品类'}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="时间范围：" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,6,0" />
                <ComboBox Width="80" Height="28"
                          ItemsSource="{Binding AvailableInventoryDays}"
                          SelectedItem="{Binding InventoryDays}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding .}" /><Run Text=" 天" />
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </WrapPanel>
        </Border>

        <!-- 趋势图 -->
        <lvc:CartesianChart Grid.Row="1"
            LegendPosition="Right"
            LegendTextPaint="{x:Static charts:ChartPaints.TooltipText}"
            Series="{Binding InventorySeries}"
            TooltipTextPaint="{x:Static charts:ChartPaints.TooltipText}"
            XAxes="{Binding InventoryXAxes}"
            YAxes="{Binding InventoryYAxes}" />
    </Grid>
</pf:Window>
