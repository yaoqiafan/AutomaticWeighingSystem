<UserControl
    x:Class="AWS.UI.Views.Camera.CameraManageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
    xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  连接栏  -->
        <Border
            Grid.Row="0"
            Padding="12,10"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="IP：" />
                <TextBox
                    Grid.Column="1"
                    Height="28"
                    Padding="6,0"
                    VerticalContentAlignment="Center"
                    Text="{Binding Ip, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Text="端口：" />
                <TextBox
                    Grid.Column="4"
                    Height="28"
                    Padding="6,0"
                    VerticalContentAlignment="Center"
                    Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Grid.Column="6"
                    VerticalAlignment="Center"
                    Text="用户名：" />
                <TextBox
                    Grid.Column="7"
                    Height="28"
                    Padding="6,0"
                    VerticalContentAlignment="Center"
                    Text="{Binding User, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Grid.Column="9"
                    VerticalAlignment="Center"
                    Text="密码：" />
                <PasswordBox
                    Grid.Column="10"
                    Height="28"
                    Padding="6,0"
                    VerticalContentAlignment="Center" />

                <!--  状态  -->
                <StackPanel
                    Grid.Column="12"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Ellipse
                        Width="8"
                        Height="8"
                        Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Gray" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#4CAF50" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="11"
                        Text="{Binding StatusText}" />
                </StackPanel>

                <Button
                    Grid.Column="14"
                    Width="64"
                    Height="28"
                    Command="{Binding ConnectCommand}"
                    Content="连 接"
                    Style="{DynamicResource ButtonPrimary}" />
                <Button
                    Grid.Column="16"
                    Width="64"
                    Height="28"
                    Command="{Binding DisconnectCommand}"
                    Content="断 开" />
            </Grid>
        </Border>

        <!--  主内容：通道列表 + 预览  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  通道列表  -->
            <Border
                Grid.Column="0"
                Padding="8"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Text="通道列表" />

                    <ListBox
                        Grid.Row="1"
                        BorderThickness="0"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding Channels}"
                        SelectedItem="{Binding SelectedChannel}" />

                    <StackPanel
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        Orientation="Vertical">
                        <Button
                            Margin="0,0,0,4"
                            Command="{Binding StartPreviewCommand}"
                            Content="开始预览" />
                        <Button
                            Margin="0,0,0,4"
                            Command="{Binding StopPreviewCommand}"
                            Content="停止预览" />
                        <Button
                            Command="{Binding CaptureCommand}"
                            Content="手动抓图"
                            Style="{DynamicResource ButtonPrimary}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  预览画面  -->
            <Border
                Grid.Column="2"
                Background="Black"
                ClipToBounds="True"
                CornerRadius="8">
                <Grid>

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#666"
                        Text="请先连接摄像机并选择通道，点击[开始预览]">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <wfi:WindowsFormsHost>
                        <wf:Panel x:Name="VideoPanel" BackColor="Black" />
                    </wfi:WindowsFormsHost>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
