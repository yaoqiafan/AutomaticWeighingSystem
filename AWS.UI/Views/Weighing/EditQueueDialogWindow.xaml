<pf:Window
    x:Class="AWS.UI.Views.Weighing.EditQueueDialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    Title="查看 / 编辑磅单"
    Width="440"
    Background="{DynamicResource WindowBrush}"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner">

    <pf:Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </pf:Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   
            <!--  磅单号  -->
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />   
            <!--  可编辑字段  -->
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />   
            <!--  备注  -->
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />   
            <!--  首次称重图片  -->
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />   
            <!--  按钮  -->
        </Grid.RowDefinitions>

        <!--  磅单号（只读）  -->
        <Border
            Grid.Row="0"
            Padding="12,10"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource LabelStyle}" Text="磅单号：" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource PrimaryBrush}"
                    Text="{Binding QueueItem.TicketNo}" />
            </StackPanel>
        </Border>

        <!--  可编辑字段  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="12" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{StaticResource LabelStyle}"
                    Text="车牌号" />
                <TextBox
                    Height="32"
                    Padding="8,0"
                    VerticalContentAlignment="Center"
                    FontSize="13"
                    Text="{Binding VehiclePlate, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="2">
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{StaticResource LabelStyle}"
                    Text="客户名称" />
                <TextBox
                    Height="32"
                    Padding="8,0"
                    VerticalContentAlignment="Center"
                    FontSize="13"
                    Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0">
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{StaticResource LabelStyle}"
                    Text="货物名称" />
                <TextBox
                    Height="32"
                    Padding="8,0"
                    VerticalContentAlignment="Center"
                    FontSize="13"
                    Text="{Binding GoodsName, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="2">
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{StaticResource LabelStyle}"
                    Text="首次重量 (kg)" />
                <TextBox
                    Height="32"
                    Padding="8,0"
                    VerticalContentAlignment="Center"
                    FontSize="13"
                    Text="{Binding FirstWeightText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

        <!--  备注  -->
        <StackPanel Grid.Row="4">
            <TextBlock
                Margin="0,0,0,4"
                Style="{StaticResource LabelStyle}"
                Text="备注" />
            <TextBox
                Height="32"
                Padding="8,0"
                VerticalContentAlignment="Center"
                FontSize="13"
                Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <!--  首次称重图片  -->
        <StackPanel Grid.Row="6">
            <TextBlock
                Margin="0,0,0,6"
                Style="{StaticResource LabelStyle}"
                Text="首次称重图片" />
            <!--  有图片：ImageViewer  -->
            <pf:ImageViewer Height="220" ImgPath="{Binding QueueItem.FirstWeighImagePath}">
                <pf:ImageViewer.Style>
                    <Style TargetType="pf:ImageViewer">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding QueueItem.FirstWeighImagePath}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </pf:ImageViewer.Style>
            </pf:ImageViewer>
            <!--  无图片：占位提示  -->
            <Border
                Height="220"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding QueueItem.FirstWeighImagePath}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    Text="（无图片）" />
            </Border>
        </StackPanel>

        <!--  操作按钮  -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="12" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="0"
                Height="38"
                Command="{Binding CancelCommand}"
                Content="取  消"
                FontSize="13" />
            <Button
                Grid.Column="2"
                Height="38"
                Background="#1976D2"
                Command="{Binding SaveCommand}"
                Content="保  存"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="White" />
        </Grid>
    </Grid>
</pf:Window>
