<Window x:Class="AWS.UI.Views.Weighing.SecondWeighDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
        Title="二次称重" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 磅单信息 -->
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" /> <!-- 实时重量 -->
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" /> <!-- 计算结果 -->
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" /> <!-- 单价/金额 -->
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" /> <!-- 备注 -->
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" /> <!-- 按钮 -->
        </Grid.RowDefinitions>

        <!-- ① 磅单基础信息 -->
        <Border Grid.Row="0" Background="{DynamicResource RegionBrush}"
                CornerRadius="6" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="磅单号" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                           Text="{Binding QueueItem.TicketNo}" Style="{StaticResource ValueStyle}"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="车牌号" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="1">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource ValueStyle}">
                            <Setter Property="Text" Value="{Binding QueueItem.VehiclePlate}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding QueueItem.VehiclePlate}" Value="{x:Null}">
                                    <Setter Property="Text" Value="—" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="货物" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="3"
                           Text="{Binding QueueItem.GoodsName}" Style="{StaticResource ValueStyle}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="首次重量" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Style="{StaticResource ValueStyle}" FontWeight="SemiBold">
                    <Run Text="{Binding QueueItem.FirstWeight, StringFormat='{}{0:F1}', Mode=OneWay}" />
                    <Run Text=" kg" />
                </TextBlock>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="入场时间" Style="{StaticResource LabelStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="3"
                           Text="{Binding QueueItem.FirstWeighTime, StringFormat='HH:mm'}"
                           Style="{StaticResource ValueStyle}" />
            </Grid>
        </Border>

        <!-- ② 实时重量 + 采集 -->
        <Border Grid.Row="2" Background="{DynamicResource RegionBrush}"
                CornerRadius="6" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 稳定指示灯 -->
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF5722" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStable}" Value="True">
                                        <Setter Property="Fill" Value="#4CAF50" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <TextBlock FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}">
                        <Run Text="{Binding CurrentWeight, StringFormat='{}{0:F1}', Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Text=" kg" FontSize="16" VerticalAlignment="Bottom"
                               Margin="4,0,0,4"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>

                <Button Grid.Column="1" Content="采 集" Width="80" Height="36"
                        Command="{Binding CaptureCommand}"
                        FontSize="13" />
            </Grid>
        </Border>

        <!-- ③ 计算结果（采集后显示） -->
        <Border Grid.Row="4"
                Visibility="{Binding HasCapturedWeight, Converter={StaticResource BoolVis}}"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="6" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="毛 重" Style="{StaticResource LabelStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}">
                        <Run Text="{Binding GrossWeight, StringFormat='{}{0:F1}', Mode=OneWay}" />
                        <Run Text=" kg" FontSize="11" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="皮 重" Style="{StaticResource LabelStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}">
                        <Run Text="{Binding TareWeight, StringFormat='{}{0:F1}', Mode=OneWay}" />
                        <Run Text=" kg" FontSize="11" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="净 重" Style="{StaticResource LabelStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="#4CAF50">
                        <Run Text="{Binding NetWeight, StringFormat='{}{0:F1}', Mode=OneWay}" />
                        <Run Text=" kg" FontSize="12" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ④ 单价 / 金额 -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="16" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="单价 (元/kg)" Style="{StaticResource LabelStyle}" Margin="0,0,0,4" />
                <TextBox Text="{Binding PriceText, UpdateSourceTrigger=PropertyChanged}"
                         Height="32" Padding="8,0" FontSize="13"
                         VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2" Visibility="{Binding HasCapturedWeight, Converter={StaticResource BoolVis}}">
                <TextBlock Text="合计金额 (元)" Style="{StaticResource LabelStyle}" Margin="0,0,0,4" />
                <Border Height="32" Background="{DynamicResource RegionBrush}"
                        CornerRadius="3" Padding="8,0">
                    <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="Bold"
                               Foreground="#4CAF50">
                        <Run Text="{Binding TotalAmount, StringFormat='{}{0:F2}', Mode=OneWay}" />
                    </TextBlock>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ⑤ 备注 -->
        <StackPanel Grid.Row="8">
            <TextBlock Text="备注更新（可选）" Style="{StaticResource LabelStyle}" Margin="0,0,0,4" />
            <TextBox Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}"
                     Height="32" Padding="8,0" FontSize="13"
                     VerticalContentAlignment="Center" />
        </StackPanel>

        <!-- ⑥ 操作按钮 -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="12" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="取  消" Height="38" FontSize="13"
                    Command="{Binding CancelCommand}" />

            <Button Grid.Column="2" Content="确 认 存 档" Height="38" FontSize="13"
                    Command="{Binding ConfirmCommand}"
                    Background="#1976D2" Foreground="White"
                    FontWeight="SemiBold" />
        </Grid>
    </Grid>
</Window>
