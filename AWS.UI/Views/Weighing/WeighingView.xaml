<UserControl x:Class="AWS.UI.Views.Weighing.WeighingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />

        <!-- 卡片样式 -->
        <Style x:Key="QueueCard" TargetType="Border">
            <Setter Property="Width" Value="200" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 字段标签 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <!-- 分区标题 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- 顶部三栏 -->
            <RowDefinition Height="Auto" />  <!-- 等待区标题 -->
            <RowDefinition Height="*" />     <!-- 卡片区 -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════
             顶部三栏
             ════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="8,8,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ① 实时重量 + 单价 -->
            <Border Grid.Column="0"
                    Background="{DynamicResource RegionBrush}"
                    CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="实时重量" Style="{StaticResource SectionTitle}" FontSize="{DynamicResource FontSize.H1.Large}" />

                    <!-- 大重量数字 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock FontSize="42" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="{Binding CurrentWeight, StringFormat='{}{0:F1}'}" />
                        <TextBlock Text="kg" FontSize="18" VerticalAlignment="Bottom"
                                   Margin="4,0,0,6"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                    </StackPanel>

                    <!-- 稳定状态 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF5722" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStable}" Value="True">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="不 稳 定" />
                                    <Setter Property="Foreground" Value="#FF5722" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStable}" Value="True">
                                            <Setter Property="Text" Value="稳  定" />
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 模拟模式标记 -->
                        <Border Background="#FF9800" CornerRadius="3" Padding="5,1"
                                Margin="8,0,0,0"
                                Visibility="{Binding IsSimulationMode, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="模拟" Foreground="White"
                                       FontSize="10" FontWeight="Bold" />
                        </Border>
                    </StackPanel>

                    <Separator Margin="0,10,0,8" />

                    <!-- 单价显示 / 快捷修改 -->
                    <TextBlock Text="默认单价" Style="{StaticResource FieldLabel}" FontSize="{DynamicResource FontSize.H1.Large}" />
                    <Grid>
                        <!-- 显示模式 -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsPriceEditing, Converter={StaticResource BoolVis},
                                                 ConverterParameter=Invert}">
                            <TextBlock FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}">
                                <Run Text="{Binding CurrentPricePerKg, StringFormat='{}{0:F2}', Mode=OneWay}" />
                                <Run Text=" 元/kg" FontSize="11" />
                            </TextBlock>
                            <Button Margin="8,0,0,0" Height="22" Width="22"
                                    Background="Transparent" BorderThickness="0"
                                    Command="{Binding StartPriceEditCommand}"
                                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolVis}}"
                                    ToolTip="修改默认单价">
                                <pf:PackIcon Kind="Pencil" Width="12" Height="12"
                                             Foreground="{DynamicResource SecondaryTextBrush}" />
                            </Button>
                        </StackPanel>

                        <!-- 编辑模式 -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPriceEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBox Text="{Binding PriceEditText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80" Height="26" Padding="4,0"
                                     VerticalContentAlignment="Center" FontSize="13" />
                            <Button Content="✓" Width="26" Height="26" Margin="4,0,2,0"
                                    Background="#4CAF50" Foreground="White" BorderThickness="0"
                                    Command="{Binding SavePriceCommand}" />
                            <Button Content="✕" Width="26" Height="26"
                                    Background="#F44336" Foreground="White" BorderThickness="0"
                                    Command="{Binding CancelPriceEditCommand}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ② 来访建立档案 -->
            <Border Grid.Column="2"
                    Background="{DynamicResource RegionBrush}"
                    CornerRadius="8" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                               Text="来访建立档案" FontSize="{DynamicResource FontSize.H1.Large}" Style="{StaticResource SectionTitle}" />

                    <!-- 车牌号 + 客户名称 -->
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="车牌号（可空）" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding VehiclePlate, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" Padding="8,0" FontSize="13"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="客户名称（可选）" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" Padding="8,0" FontSize="13"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>

                    <!-- 货物类别 + 备注 -->
                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <TextBlock Text="货物类别 *" Style="{StaticResource FieldLabel}" />
                        <ComboBox ItemsSource="{Binding GoodsCategories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  DisplayMemberPath="Name"
                                  Height="30" FontSize="13" />
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="2">
                        <TextBlock Text="备注（可选）" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" Padding="8,0" FontSize="13"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>

                    <!-- 采集重量区 -->
                    <Grid Grid.Row="6" Grid.ColumnSpan="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 已采集重量显示 -->
                        <Border Grid.Column="0" Height="36" Background="{DynamicResource WindowBrush}"
                                CornerRadius="4" Padding="10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="12" Text="采集重量：" />
                                <TextBlock FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="— 请采集 —" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCapturedWeight}" Value="True">
                                                    <Setter Property="Text"
                                                            Value="{Binding CapturedWeight, StringFormat='{}{0:F1} kg'}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Button Grid.Column="2" Content="采 集 重 量" Height="36" Width="110"
                                Command="{Binding CaptureWeightCommand}"
                                FontSize="13" />
                    </Grid>

                    <!-- 确认入场 -->
                    <Button Grid.Row="8" Grid.ColumnSpan="3"
                            Content="确  认  入  场" Height="40"
                            Command="{Binding ConfirmEntryCommand}"
                            Background="#1976D2" Foreground="White"
                            FontSize="14" FontWeight="SemiBold"
                            BorderThickness="0" />
                </Grid>
            </Border>

            <!-- ④ 今日收货统计 -->
            <Border Grid.Column="4"
                    Background="{DynamicResource RegionBrush}"
                    CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="今日收货统计" FontSize="{DynamicResource FontSize.H1.Large}"
                               Style="{StaticResource SectionTitle}" />

                    <!-- LiveCharts 折线图 -->
                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding HourlySeries}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}" />

                    <!-- 汇总数字 -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="合计净重"
                                       FontSize="10"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TodayTotalWeight}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="今日车次"
                                       FontSize="10"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       HorizontalAlignment="Center">
                                <Run Text="{Binding TodayVehicleCount, Mode=OneWay}" />
                                <Run Text=" 次" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════
             等待区标题栏
             ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Margin="8,8,8,0"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="6,6,0,0" Padding="14,6">
            <StackPanel Orientation="Horizontal">
                <pf:PackIcon Kind="TruckDelivery" Width="16" Height="16"
                             Foreground="{DynamicResource PrimaryBrush}"
                             VerticalAlignment="Center" />
                <TextBlock Text="卸货等待区" Margin="6,0,0,0"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Margin="8,0,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="11" VerticalAlignment="Center">
                    <Run Text="共 " />
                    <Run Text="{Binding QueueItems.Count, Mode=OneWay}" />
                    <Run Text=" 辆待处理  — 点击卡片进行二次称重" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════
             ③ 卡片瀑布流
             ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="8,0,8,8"
                Background="{DynamicResource RegionBrush}"
                CornerRadius="0,0,6,6">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding QueueItems}"
                              Margin="4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource QueueCard}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseLeftButtonDown">
                                        <i:InvokeCommandAction
                                            Command="{Binding DataContext.CardClickCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>

                                <Grid Margin="12,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="4" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="4" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="4" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- 磅单号 -->
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding TicketNo}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" />

                                    <!-- 车牌 -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <pf:PackIcon Kind="Car" Width="12" Height="12"
                                                     Foreground="{DynamicResource SecondaryTextBrush}"
                                                     VerticalAlignment="Center" />
                                        <TextBlock Margin="4,0,0,0" FontSize="11"
                                                   Foreground="{DynamicResource PrimaryTextBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding VehiclePlate}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VehiclePlate}" Value="{x:Null}">
                                                            <Setter Property="Text" Value="无车牌" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- 货物 -->
                                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                                        <pf:PackIcon Kind="Package" Width="12" Height="12"
                                                     Foreground="{DynamicResource SecondaryTextBrush}"
                                                     VerticalAlignment="Center" />
                                        <TextBlock Margin="4,0,0,0" FontSize="11"
                                                   Text="{Binding GoodsName}"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>

                                    <!-- 毛重 + 时间 -->
                                    <StackPanel Grid.Row="6" Orientation="Horizontal">
                                        <TextBlock FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}">
                                            <Run Text="{Binding FirstWeight, StringFormat='{}{0:F1}'}" />
                                            <Run Text=" kg" FontSize="10" />
                                        </TextBlock>
                                        <TextBlock Margin="8,0,0,0" FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Text="{Binding FirstWeighTime, StringFormat='HH:mm'}"
                                                   VerticalAlignment="Bottom" />
                                    </StackPanel>

                                    <!-- 状态标签 -->
                                    <Border Grid.Row="8" CornerRadius="4" Padding="8,3"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E3F2FD" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="1">
                                                        <Setter Property="Background" Value="#FFF3E0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="初次录入" />
                                                    <Setter Property="Foreground" Value="#1565C0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="1">
                                                            <Setter Property="Text" Value="卸货中" />
                                                            <Setter Property="Foreground" Value="#E65100" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
