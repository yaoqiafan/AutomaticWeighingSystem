<UserControl
    x:Class="AWS.UI.Views.BasicData.BasicDataView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True">



    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部工具栏  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,8"
            Padding="12,8"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <pf:PackIcon
                        Width="18"
                        Height="18"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Kind="ClipboardListOutline" />
                    <TextBlock
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSize.H2.Title}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Text="基础数据综合管理" />
                </StackPanel>
                <Button
                    HorizontalAlignment="Right"
                    BorderThickness="0"
                    Command="{Binding SaveAllCommand}"
                    Content="保存全部"
                    DockPanel.Dock="Right"
                    Foreground="White"
                    Style="{StaticResource ButtonSuccess}" />
            </DockPanel>
        </Border>

        <!--  三页签  -->
        <Border
            Grid.Row="1"
            Padding="8"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="6">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <GroupBox
                    Grid.Column="1"
                    Margin="0,0,4,0"
                    Header="客户管理">
                    <Grid Margin="4,8,4,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel
                            Grid.Row="0"
                            Margin="0,0,0,6"
                            Orientation="Horizontal">
                            <Button
                                Margin="10,0,10,0"
                                BorderThickness="0"
                                Command="{Binding AddCustomerCommand}"
                                Content="新增"
                                Style="{StaticResource ButtonInfo}" />
                            <Button
                                BorderThickness="0"
                                Command="{Binding DeleteCustomerCommand}"
                                Content="删除"
                                Style="{StaticResource ButtonDanger}" />
                        </StackPanel>
                        <DataGrid
                            Grid.Row="1"
                            AutoGenerateColumns="False"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            GridLinesVisibility="Horizontal"
                            ItemsSource="{Binding Customers}"
                            SelectedItem="{Binding SelectedCustomer}"
                            SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="客户名称" />
                                <DataGridTextColumn
                                    Width="140"
                                    Binding="{Binding Phone}"
                                    Header="联系电话" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Address}"
                                    Header="地址" />
                                <DataGridCheckBoxColumn
                                    Width="60"
                                    Binding="{Binding IsActive}"
                                    Header="启用" />
                                <DataGridTextColumn
                                    Width="110"
                                    Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}"
                                    Header="创建时间"
                                    IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <GroupBox
                    Grid.Column="0"
                    Margin="4,0"
                    Header="货物种类">
                    <Grid Margin="4,8,4,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel
                            Grid.Row="0"
                            Margin="0,0,0,6"
                            Orientation="Horizontal">
                            <Button
                                Margin="10,0,10,0"
                                BorderThickness="0"
                                Command="{Binding AddGoodsCommand}"
                                Content="新增"
                                Style="{StaticResource ButtonInfo}" />
                            <Button
                                BorderThickness="0"
                                Command="{Binding DeleteGoodsCommand}"
                                Content="删除"
                                Style="{StaticResource ButtonDanger}" />
                        </StackPanel>
                        <DataGrid
                            Grid.Row="1"
                            AutoGenerateColumns="False"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            GridLinesVisibility="Horizontal"
                            ItemsSource="{Binding GoodsCategories}"
                            SelectedItem="{Binding SelectedGoods}"
                            SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="货物名称" />
                                <DataGridTextColumn
                                    Width="90"
                                    Binding="{Binding PricePerUnit, StringFormat=F2}"
                                    Header="单价(元/kg)" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Remark}"
                                    Header="备注" />
                                <DataGridCheckBoxColumn
                                    Width="60"
                                    Binding="{Binding IsActive}"
                                    Header="启用" />
                                <DataGridTextColumn
                                    Width="110"
                                    Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}"
                                    Header="创建时间"
                                    IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <GroupBox
                    Grid.Column="2"
                    Margin="4,0,0,0"
                    Header="车辆管理">
                    <Grid Margin="4,8,4,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel
                            Grid.Row="0"
                            Margin="0,0,0,6"
                            Orientation="Horizontal">
                            <Button
                                Margin="10,0,10,0"
                                BorderThickness="0"
                                Command="{Binding AddVehicleCommand}"
                                Content="新增"
                                Style="{StaticResource ButtonInfo}" />
                            <Button
                                BorderThickness="0"
                                Command="{Binding DeleteVehicleCommand}"
                                Content="删除"
                                Style="{StaticResource ButtonDanger}" />
                        </StackPanel>
                        <DataGrid
                            Grid.Row="1"
                            AutoGenerateColumns="False"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            GridLinesVisibility="Horizontal"
                            ItemsSource="{Binding Vehicles}"
                            SelectedItem="{Binding SelectedVehicle}"
                            SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="160"
                                    Binding="{Binding PlateNumber}"
                                    Header="车牌号" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Remark}"
                                    Header="备注" />
                                <DataGridCheckBoxColumn
                                    Width="60"
                                    Binding="{Binding IsActive}"
                                    Header="启用" />
                                <DataGridTextColumn
                                    Width="110"
                                    Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}"
                                    Header="创建时间"
                                    IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
