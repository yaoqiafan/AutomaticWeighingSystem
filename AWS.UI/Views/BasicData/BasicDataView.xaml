<UserControl x:Class="AWS.UI.Views.BasicData.BasicDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <!-- 通用 DataGrid 样式 -->
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="GridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
        <!-- 工具按钮 -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Width" Value="72" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <pf:PackIcon Kind="ClipboardListOutline" Width="18" Height="18"
                                 Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="基础数据综合管理" Margin="6,0,0,0"
                               FontSize="{DynamicResource FontSize.H2.Title}" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
                <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                        Content="保存全部" Style="{StaticResource ToolBtn}"
                        Command="{Binding SaveAllCommand}"
                        Background="#4CAF50" Foreground="White" BorderThickness="0" />
            </DockPanel>
        </Border>

        <!-- 三页签 -->
        <Border Grid.Row="1" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="8">
            <TabControl Background="Transparent" Padding="0">

                <!-- ═══ 客户 ═══ -->
                <TabItem Header=" 客户管理 " FontSize="13">
                    <Grid Margin="4,8,4,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="新增" Style="{StaticResource ToolBtn}"
                                    Command="{Binding AddCustomerCommand}"
                                    Background="#1976D2" Foreground="White" BorderThickness="0" />
                            <Button Content="删除" Style="{StaticResource ToolBtn}"
                                    Command="{Binding DeleteCustomerCommand}"
                                    Background="#F44336" Foreground="White" BorderThickness="0" />
                        </StackPanel>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Customers}"
                                  SelectedItem="{Binding SelectedCustomer}"
                                  AutoGenerateColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Single" FontSize="12" RowHeight="28" ColumnHeaderHeight="30"
                                  ColumnHeaderStyle="{StaticResource GridHeader}"
                                  CellStyle="{StaticResource GridCell}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="客户名称" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="联系电话" Binding="{Binding Phone}" Width="140" />
                                <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="*" />
                                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="60" />
                                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="110" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ═══ 货物种类 ═══ -->
                <TabItem Header=" 货物种类 " FontSize="13">
                    <Grid Margin="4,8,4,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="新增" Style="{StaticResource ToolBtn}"
                                    Command="{Binding AddGoodsCommand}"
                                    Background="#1976D2" Foreground="White" BorderThickness="0" />
                            <Button Content="删除" Style="{StaticResource ToolBtn}"
                                    Command="{Binding DeleteGoodsCommand}"
                                    Background="#F44336" Foreground="White" BorderThickness="0" />
                        </StackPanel>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding GoodsCategories}"
                                  SelectedItem="{Binding SelectedGoods}"
                                  AutoGenerateColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Single" FontSize="12" RowHeight="28" ColumnHeaderHeight="30"
                                  ColumnHeaderStyle="{StaticResource GridHeader}"
                                  CellStyle="{StaticResource GridCell}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="货物名称" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*" />
                                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="60" />
                                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="110" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ═══ 车辆 ═══ -->
                <TabItem Header=" 车辆管理 " FontSize="13">
                    <Grid Margin="4,8,4,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="新增" Style="{StaticResource ToolBtn}"
                                    Command="{Binding AddVehicleCommand}"
                                    Background="#1976D2" Foreground="White" BorderThickness="0" />
                            <Button Content="删除" Style="{StaticResource ToolBtn}"
                                    Command="{Binding DeleteVehicleCommand}"
                                    Background="#F44336" Foreground="White" BorderThickness="0" />
                        </StackPanel>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Vehicles}"
                                  SelectedItem="{Binding SelectedVehicle}"
                                  AutoGenerateColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Single" FontSize="12" RowHeight="28" ColumnHeaderHeight="30"
                                  ColumnHeaderStyle="{StaticResource GridHeader}"
                                  CellStyle="{StaticResource GridCell}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="车牌号" Binding="{Binding PlateNumber}" Width="160" />
                                <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*" />
                                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="60" />
                                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="110" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
